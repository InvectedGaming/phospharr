# Phospharr config
PORT=7777
# Public base URL clients use to reach this server (HDHR discovery advertises it)
BASE_URL=http://localhost:7777
# SQLite file (Postgres support is a documented next step)
DATABASE_URL=./phospharr.db
# Number of "tuners" Phospharr advertises to HDHR consumers (Plex/Jellyfin)
HDHR_TUNER_COUNT=8
# Seconds to keep a channel's upstream warm after the last viewer leaves
# (instant re-tune). Also settable in the UI under Settings → Streaming.
PHOSPHARR_STREAM_KEEPWARM=5
# ffmpeg binary for the browser audio-transcode fallback (/watch). Default: PATH lookup.
FFMPEG_PATH=ffmpeg

# ─────────────────────────────────────────────────────────────────────────────
# Docker / docker-compose (only needed when running via compose)
# ─────────────────────────────────────────────────────────────────────────────
# Host port to publish the UI on.
PHOSPHARR_PORT=7777
# Timezone (for logs + EPG clock).
TZ=UTC
# Pin the stream/tuner key (gates /stream + HDHR + M3U/EPG exports). Blank =
# auto-generated; see it in the UI under Settings → Access & Tuner.
PHOSPHARR_STREAM_KEY=
# Allow exports off the local network (true/false). Default false = LAN-only.
PHOSPHARR_ALLOW_EXTERNAL=false
# Trust X-Forwarded-For for the LAN check (set true behind a reverse proxy).
PHOSPHARR_TRUST_PROXY=false

# ── VPN passthrough (Gluetun) ──
# Run one Gluetun per region; add each as an endpoint in Settings → VPN, then
# pick which VPN each Source uses. The compose ships a `gluetun-jp` example —
# copy the block per region. Provider config: https://github.com/qdm12/gluetun-wiki
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# OPENVPN_USER=your-user          # if VPN_TYPE=openvpn
# OPENVPN_PASSWORD=your-pass
# Per-region (Japan example — matches gluetun-jp in docker-compose.yml):
# JP_WIREGUARD_PRIVATE_KEY=your-key
# JP_WIREGUARD_ADDRESSES=10.0.0.2/32
# JP_SERVER_COUNTRIES=Japan
