# Cathode config
PORT=7777
# Public base URL clients use to reach this server (HDHR discovery advertises it)
BASE_URL=http://localhost:7777
# SQLite file (Postgres support is a documented next step)
DATABASE_URL=./cathode.db
# Number of "tuners" Cathode advertises to HDHR consumers (Plex/Jellyfin)
HDHR_TUNER_COUNT=8
# Seconds to keep a channel's upstream warm after the last viewer leaves
# (instant re-tune). Also settable in the UI under Settings → Streaming.
CATHODE_STREAM_KEEPWARM=5
# ffmpeg binary for the browser audio-transcode fallback (/watch). Default: PATH lookup.
FFMPEG_PATH=ffmpeg

# ─────────────────────────────────────────────────────────────────────────────
# Docker / docker-compose (only needed when running via compose)
# ─────────────────────────────────────────────────────────────────────────────
# Host port to publish the UI on.
CATHODE_PORT=7777
# Timezone (for logs + EPG clock).
TZ=UTC

# ── VPN passthrough (Gluetun) ──
# Proxy URL Cathode routes VPN-flagged sources through. With the bundled gluetun
# service, use http://gluetun:8888. Leave blank to set it in the UI instead.
CATHODE_VPN_PROXY=
# Gluetun VPN provider config — see https://github.com/qdm12/gluetun-wiki
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=your-key
# WIREGUARD_ADDRESSES=10.0.0.2/32
# SERVER_COUNTRIES=Netherlands
# For OpenVPN providers instead:
# VPN_TYPE=openvpn
# OPENVPN_USER=your-user
# OPENVPN_PASSWORD=your-pass
